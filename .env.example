# Copie este arquivo para .env e preencha com a sua chave real.
# IMPORTANTE: nunca faca commit do arquivo .env (ele esta no .gitignore).

# Provedor padrao: OpenAI
OPENAI_API_KEY=sk-coloque-sua-chave-aqui

# Alternativa: Groq (descomente e use se preferir)
# GROQ_API_KEY=gsk-coloque-sua-chave-aqui

# (Opcional) Identificador de usuario padrao usado nos testes pelo Studio
# AGNO_DEFAULT_USER_ID=adrian
